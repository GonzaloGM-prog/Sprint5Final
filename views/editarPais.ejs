<!DOCTYPE html>
<html>

<head>

    <title>Editar País</title>
    <link rel="stylesheet" href="/css/styles.css">

</head>

<body>

<%- include('partials/navbar') %>

<h1>Editar País</h1>

<form action="/api/paises/editar/<%= pais._id %>" method="POST">

    <div>

        <label>Nombre</label>

        <input
            type="text"
            name="name"
            value="<%= pais.name %>"
        >

        <% errores?.forEach(error => { %>

            <% if(error.path === 'name') { %>

                <p style="color:red;">

                    <%= error.msg %>

                </p>

            <% } %>

        <% }) %>

    </div>

    <br>

    <div>

        <label>Capital</label>

        <input
            type="text"
            name="capital"
            value="<%= pais.capital %>"
        >

        <% errores?.forEach(error => { %>

            <% if(error.path === 'capital') { %>

                <p style="color:red;">

                    <%= error.msg %>

                </p>

            <% } %>

        <% }) %>

    </div>

    <br>

    <div>

        <label>Población</label>

        <input
            type="number"
            name="population"
            value="<%= pais.population %>"
        >

        <% errores?.forEach(error => { %>

            <% if(error.path === 'population') { %>

                <p style="color:red;">

                    <%= error.msg %>

                </p>

            <% } %>

        <% }) %>

    </div>

    <br>

    <div>

        <label>Área</label>

        <input
            type="number"
            name="area"
            value="<%= pais.area %>"
        >

        <% errores?.forEach(error => { %>

            <% if(error.path === 'area') { %>

                <p style="color:red;">

                    <%= error.msg %>

                </p>

            <% } %>

        <% }) %>

    </div>

    <br>

    <div>

        <label>Región</label>

        <input
            type="text"
            name="region"
            value="<%= pais.region %>"
        >

    </div>

    <br>

    <div>

        <label>Timezone</label>

        <input
            type="text"
            name="timezones"
            value="<%= pais.timezones %>"
        >

    </div>

    <br>

    <button type="submit">

        Actualizar

    </button>

</form>

<%- include('partials/footer') %>

</body>
</html>